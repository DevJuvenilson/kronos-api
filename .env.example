# Copy this file to .env and replace all change-me values before starting.
KRONOS_API_PORT=8080
POSTGRES_DB=kronos_db
POSTGRES_USER=kronos
POSTGRES_PASSWORD=change-me-use-a-long-random-password
API_SECURITY_TOKEN_SECRET=change-me-use-at-least-32-random-bytes
API_SECURITY_TOKEN_ISSUER=kronos-api
API_SECURITY_TOKEN_EXPIRATION_HOURS=2